SELECT ROUND(DECIMAL(AVG(LAT_N),10,4),4) FROM (SELECT LAT_N, ROW_NUMBER() OVER(ORDER BY LAT_N) r, COUNT(*) OVER() c FROM STATION) t WHERE r IN (INT((c+1)/2), INT((c+2)/2));
